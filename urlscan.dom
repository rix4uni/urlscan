            <span class="glyphicon glyphicon-play" aria-hidden="true"></span> <span id="submitbtn_text" class="hidden-xs hidden-sm">Public Scan</span>
          </button>
          <button type="submit" class="btn btn-default disabled display-none" id="countrybtn" style="display: none;">
          </button>
          <a data-toggle="collapse" data-target="#options" aria-expanded="false" aria-controls="options" class="btn btn-default"><span class="glyphicon glyphicon-cog" aria-hidden="true"></span>
            <span class="hidden-sm hidden-xs">Options</span></a>
