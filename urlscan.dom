              <label for="vispublic"><span class="label label-success">Public</span></label>
            </span>
            <span class="right10">
              <input id="visunlisted" type="radio" class="visibility" name="visibility" value="unlisted">
              <label for="visunlisted"><span class="label label-info">Unlisted</span></label>
            </span>
            <span class="right10">
              <input id="visprivate" type="radio" class="visibility" name="visibility" value="private">
              <label for="visprivate"><span class="label label-warning">Private</span></label>
            </span>
            <div>
            <span class="text-muted">Make sure you understand the different <a href="/docs/api/" target="_blank">visibility levels</a>.</span>
